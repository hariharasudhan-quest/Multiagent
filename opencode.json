{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "qwen3:8b": { "name": "Qwen 3 8B (Local)" },
        "qwen3.5:9b": { "name": "Qwen 3.5 9B (Local)" },
        "qwen3.5:9b-32k": { "name": "Qwen 3.5 9B 32K (Local)" },
        "ornith:9b": { "name": "Ornith 9B (Local)" }
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "options": {
        "apiKey": "${GOOGLE_API_KEY}"
      },
      "models": {
        "gemini-2.5-flash": { "name": "Gemini 2.5 Flash (Cloud)" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "headers": {
          "HTTP-Referer": "http://localhost:3000",
          "X-Title": "Agent TS"
        }
      },
      "models": {
        "qwen/qwen3-coder-30b-a3b-thinking": {
          "name": "Qwen 3 Coder 30B A3B Thinking (Cloud)"
        }
      }
    }
  }
}