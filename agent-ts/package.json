{
  "name": "agent-ts",
  "version": "1.0.0",
  "type": "module",
  "description": "Agentic coding pipeline using OpenCode SDK",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "proxy": "tsx src/proxy.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@opencode-ai/sdk": "latest",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/auto-instrumentations": "^0.40.3",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.45.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.45.1",
    "@opentelemetry/instrumentation-http": "^0.45.1",
    "@opentelemetry/instrumentation-express": "^0.34.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
